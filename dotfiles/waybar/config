{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["pulseaudio", "network", "battery", "tray", "clock", "custom/power"],

    "hyprland/workspaces": {"format": "{name}"},

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "{signalStrength}%  ",
        "format-ethernet": "󰈀",
        "format-disconnected": "⚠",
        "tooltip-format": "{essid} via {ifname}",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["", "", "", "", ""]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "clock": {"format": "{:%H:%M}"},

    "custom/power": {
        "format": " ⏻ ", 
        "on-click": "wlogout"
    }
}
